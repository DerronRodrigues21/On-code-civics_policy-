<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Complaints Map | CivicConnect AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/all.min.css">
</head>
<body>
    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">CivicConnect AI</a>
            <a href="/report" class="btn btn-outline-light btn-sm">New Complaint</a>
        </div>
    </nav>
    <div class="container mt-3">
        <div class="card border-0 shadow-sm p-3">
            <div class="d-flex flex-wrap gap-3">
                <span><span style="background:#FF5733" class="legend-dot"></span> Roads & Transport</span>
                <span><span style="background:#3498DB" class="legend-dot"></span> Water Supply</span>
                <span><span style="background:#2ECC71" class="legend-dot"></span> Health Department</span>
                <span><span style="background:#2C3E50" class="legend-dot"></span> Police Department</span>
                <span><span style="background:#8B4513" class="legend-dot"></span> Waste Management</span>
                <span><span style="background:#9B59B6" class="legend-dot"></span> Education Department</span>
                <span><span style="background:#F39C12" class="legend-dot"></span> Housing Department</span>
                <span><span style="background:#F1C40F" class="legend-dot"></span> Electricity Board</span>
                <span><span style="background:#27AE60" class="legend-dot"></span> Parks & Recreation</span>
            </div>
        </div>
    </div>
    <div id="map" style="height: calc(100vh - 140px); width: 100%;"></div>
    <style>
        .legend-dot { display: inline-block; width: 12px; height: 12px; border-radius: 50%; margin-right: 4px; }
    </style>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
    <script src="/javascripts/map.js"></script>
</body>
</html>