<!-- report.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Report Issue | CivicConnect AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="/stylesheets/report.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">CivicConnect AI</a>
            <span class="text-white-50">New Complaint</span>
        </div>
    </nav>

    <div class="container my-5">
        <div class="row g-4">
            <div class="col-lg-5">
                <div class="card shadow-sm border-0 p-4">
                    <h3 class="fw-bold mb-4">Report an Issue</h3>
                    <form id="reportForm" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Describe the Problem</label>
                            <textarea id="description" class="form-control" rows="4" placeholder="e.g., There is a large pothole at the intersection of Main St..." required></textarea>
                            <div id="aiSuggestion" class="form-text text-primary mt-2"></div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Upload Photo</label>
                            <input type="file" id="image" class="form-control" accept="image/*">
                        </div>

                        <input type="hidden" id="lat">
                        <input type="hidden" id="lng">

                        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold" id="submitBtn">
                            Submit to AI Router
                        </button>
                    </form>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="card shadow-sm border-0 overflow-hidden">
                    <div class="p-3 bg-white border-bottom d-flex justify-content-between align-items-center">
                        <span class="fw-bold"><i class="fas fa-map-marker-alt"></i> Select Location</span>
                        <button class="btn btn-sm btn-outline-secondary" onclick="getLocation()">Use My Location</button>
                    </div>
                    <div id="map" style="height: 500px;"></div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="/javascripts/report.js"></script>
</body>
</html>