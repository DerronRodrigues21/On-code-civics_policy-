<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CivicConnect AI | Smart Governance</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/all.min.css">
    <link rel="stylesheet" href="stylesheets/home.css">
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#"><i class="fas fa-city me-2"></i>CivicConnect AI</a>
            <div class="ms-auto">
                <a href="auth.html" class="btn btn-outline-light btn-sm">Login / Signup</a>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <header class="hero-section text-center text-white d-flex align-items-center">
        <div class="container">
            <h1 class="display-3 fw-bold">Bridge the Gap. Fix Your City.</h1>
            <p class="lead">Report civic issues in seconds. Our AI ensures it reaches the right department instantly.</p>
            <div class="mt-4">
                <a href="report.html" class="btn btn-primary btn-lg px-5 py-3 me-sm-3 fw-bold">Report an Issue</a>
                <a href="#track" class="btn btn-light btn-lg px-5 py-3 fw-bold text-primary">Track Status</a>
            </div>
        </div>
    </header>

    <!-- Features Section -->
    <section class="py-5 bg-light">
        <div class="container">
            <div class="row text-center">
                <div class="col-md-4 mb-4">
                    <div class="feature-card p-4 shadow-sm bg-white rounded">
                        <i class="fas fa-robot fa-3x text-primary mb-3"></i>
                        <h4>AI Categorization</h4>
                        <p class="text-muted">No manual sorting. Gemini AI routes your complaint to the correct official.</p>
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="feature-card p-4 shadow-sm bg-white rounded">
                        <i class="fas fa-map-marker-alt fa-3x text-danger mb-3"></i>
                        <h4>Geo-Tagging</h4>
                        <p class="text-muted">Precise location capturing ensures help arrives exactly where it's needed.</p>
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="feature-card p-4 shadow-sm bg-white rounded">
                        <i class="fas fa-check-circle fa-3x text-success mb-3"></i>
                        <h4>Transparency</h4>
                        <p class="text-muted">Real-time tracking from submission to resolution. No more black holes.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Tracking Search Section -->
    <section id="track" class="py-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-6 text-center">
                    <h2 class="fw-bold mb-4">Track Your Complaint</h2>
                    <div class="input-group mb-3 shadow-sm">
                        <input type="text" id="ticketId" class="form-control form-control-lg" placeholder="Enter Ticket ID (e.g., #CIV123)">
                        <button class="btn btn-primary px-4" type="button" id="btnTrack">Search</button>
                    </div>
                    <div id="searchResult" class="mt-3"></div>
                </div>
            </div>
        </div>
    </section>

    <footer class="bg-dark text-white py-4 text-center">
        <p>&copy; 2024 CivicConnect AI | Building Smarter Cities</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="script.js"></script>
</body>
</html>