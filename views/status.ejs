<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Track Complaint | CivicConnect AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/all.min.css">
    <link rel="stylesheet" href="/stylesheets/status.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">CivicConnect AI</a>
            <a href="/report" class="btn btn-outline-light btn-sm">My Reports</a>
        </div>
    </nav>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow-sm border-0 mb-4 p-4 text-center">
                    <span class="badge bg-primary mb-2 mx-auto" style="width: fit-content;">Ticket #CIV9842</span>
                    <h2 class="fw-bold">Broken Streetlight</h2>
                    <p class="text-muted">Reported on Oct 24, 2024 • Location: Sector 5, Zone B</p>
                    <div class="d-flex justify-content-center gap-2">
                        <span class="badge bg-info text-dark"><i class="fas fa-bolt me-1"></i> Electricity Dept</span>
                        <span class="badge bg-warning text-dark"><i class="fas fa-exclamation-triangle me-1"></i> Medium Priority</span>
                    </div>
                </div>

                <div class="card shadow-sm border-0 mb-4 p-3 border-start border-primary border-5">
                    <h6 class="fw-bold text-primary"><i class="fas fa-robot me-2"></i> AI Action Summary</h6>
                    <p class="mb-0 italic small">"The issue was automatically categorized as an electrical failure and routed to the Junior Engineer for Sector 5."</p>
                </div>

                <div class="card shadow-sm border-0 p-4 mb-5">
                    <h5 class="fw-bold mb-4">Resolution Timeline</h5>
                    <div class="timeline">
                        <div class="timeline-item active">
                            <div class="timeline-icon bg-success"><i class="fas fa-check"></i></div>
                            <div class="timeline-content">
                                <h6 class="fw-bold">Complaint Submitted</h6>
                                <p class="text-muted small">Oct 24, 10:00 AM</p>
                            </div>
                        </div>
                        <div class="timeline-item active">
                            <div class="timeline-icon bg-success"><i class="fas fa-robot"></i></div>
                            <div class="timeline-content">
                                <h6 class="fw-bold">AI Categorized: Electricity</h6>
                                <p class="text-muted small">Oct 24, 10:01 AM</p>
                            </div>
                        </div>
                        <div class="timeline-item active">
                            <div class="timeline-icon bg-primary"><i class="fas fa-user-cog"></i></div>
                            <div class="timeline-content">
                                <h6 class="fw-bold">Assigned to Field Engineer</h6>
                                <p class="text-muted small">Oct 24, 02:30 PM</p>
                            </div>
                        </div>
                        <div class="timeline-item">
                            <div class="timeline-icon bg-secondary"><i class="fas fa-tools"></i></div>
                            <div class="timeline-content">
                                <h6 class="fw-bold">Resolution in Progress</h6>
                                <p class="text-muted small">Pending</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/javascripts/status.js"></script>
</body>
</html>