<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Join CivicConnect AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/all.min.css">
    <link rel="stylesheet" href="stylesheets/signup.css">
</head>
<body class="bg-light">

    <div class="container d-flex justify-content-center align-items-center vh-100">
        <div class="card shadow-lg auth-card">
            <div class="row g-0">
                <div class="col-md-5 d-none d-md-flex bg-primary text-white align-items-center justify-content-center p-4 text-center">
                    <div>
                        <i class="fas fa-shield-alt fa-4x mb-3"></i>
                        <h2 class="fw-bold">Welcome!</h2>
                        <p>Join thousands of citizens making their city smarter and safer.</p>
                        <a href="/" class="btn btn-outline-light btn-sm mt-3">Back to Home</a>
                    </div>
                </div>
                
                <div class="col-md-7 p-4 p-lg-5 bg-white">
                    <h3 class="fw-bold mb-3" id="authTitle">Create Account</h3>
                    
                    <div class="btn-group w-100 mb-4" role="group">
                        <input type="radio" class="btn-check" name="role" id="roleCitizen" checked>
                        <label class="btn btn-outline-primary" for="roleCitizen">Citizen</label>
                        
                        <input type="radio" class="btn-check" name="role" id="roleOfficial">
                        <label class="btn btn-outline-primary" for="roleOfficial">Official</label>
                    </div>

                    <form id="signupForm" method="post" action="/signup">
                        <div class="mb-3">
                            <label class="form-label">Full Name</label>
                            <input type="text" class="form-control" id="userName" placeholder="Full Name" required name="name">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email Address</label>
                            <input type="email" class="form-control" id="userEmail" placeholder="name@example.com" required name="email">
                        </div>
                        <!-- <div class="mb-3">
                            <label class="form-label">Phone Number</label>
                            <input type="tel" class="form-control" id="userPhone" placeholder="123-456-7890" required>
                        </div> -->
                        <div class="mb-3" id="deptField" style="display: none;">
                            <label class="form-label">Department ID</label>
                            <input type="text" class="form-control" id="deptId" placeholder="e.g. WATER_DEPT_01" name="deptId">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Password</label>
                            <input type="password" class="form-control" id="userPass" required name="password">
                        </div>
                        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">Sign Up</button>
                    </form>

                    <div class="text-center mt-4">
                        <p class="small text-muted">Already have an account? <a href="/login" id="toggleLink">Login here</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="javascripts/signup.js"></script>
</body>
</html>